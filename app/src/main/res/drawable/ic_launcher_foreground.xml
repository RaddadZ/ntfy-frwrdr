        <path
            android:pathData="M 342 652 A 40 40 0 0 0 422 652"
            android:strokeColor="#F8FAFC"
            android:strokeWidth="64"
            android:strokeLineCap="round" />

        <!-- Invisible Cutout to create the gap for the arrow -->
